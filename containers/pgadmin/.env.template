# =============================================================================
# pgAdmin 4 - Environment Template
# =============================================================================
# Copy this file to .env and fill in the values.
# chmod 600 .env after editing.
# Never commit .env to version control.
# =============================================================================

# IP address to bind the pgAdmin port to.
# Use your Tailscale IP to restrict access to the mesh only.
PGADMIN_BIND_IP=

# pgAdmin login credentials.
# These are set on first startup and stored in the pgadmin_data volume.
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD= 