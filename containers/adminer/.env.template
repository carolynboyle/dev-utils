# =============================================================================
# Adminer - Environment Template
# =============================================================================
# Copy this file to .env and fill in the values.
# chmod 600 .env after editing.
# Never commit .env to version control.
# =============================================================================

# IP address to bind the Adminer port to.
# Use your Tailscale IP to restrict access to the mesh only.
ADMINER_BIND_IP=100.64.0.9

# UID and GID to run the Adminer process as inside the container.
# Run `id` on the host to find your UID and GID.
ADMINER_UID=1000
ADMINER_GID=1000
